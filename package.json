{
  "name": "GlyphConnect",
  "version": "1.0.0",
  "description": "P2P remote desktop application with E2E encrypted screen sharing, chat and file transfer",
  "author": "Paarth & Aayushi",
  "private": true,
  "main": "backend/dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:signaling\" \"npm run dev:frontend\" \"npm run dev:desktop\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:desktop": "wait-on http://localhost:5173 && npm run dev --prefix backend",
    "dev:signaling": "cd signaling-server && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npx tsc",
    "build:all": "npm run build:frontend && npm run build:backend",
    "build:win": "npm run build:all && electron-builder --win --x64",
    "build:linux": "npm run build:all && electron-builder --linux AppImage",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ../signaling-server && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.glyphconnect.GlyphConnect",
    "productName": "GlyphConnect",
    "extraMetadata": {
      "main": "backend/dist/main.js"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "backend/dist/**/*",
      "backend/renderer/**/*",
      "backend/node_modules/**/*",
      "backend/package.json",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    },
    "asarUnpack": [
      "backend/node_modules/@nut-tree-fork/**"
    ]
  },
  "dependencies": {}
}
